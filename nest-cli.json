{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"language": "ts",
	"generateOptions": {
		"spec": false
	},
	"compilerOptions": {
		"deleteOutDir": true,
		"assets": [
			{
				"include": "**/Languages",
				"watchAssets": true,
				"outDir": "dist/src/"
			},
			{
				"include": "**/assets",
				"watchAssets": true,
				"outDir": "dist/src/"
			}
		]
	}
}
